{
  "name": "@arbitrum-miniapp/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run routes && vite build",
    "preview": "vite preview",
    "routes": "npx @tanstack/router-cli generate-routefiles --routesDirectory src/routes",
    "lint": "npx eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "npx eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\""
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.14",
    "@tanstack/react-query": "5.90.12",
    "lucide-react": "0.563.0",
    "prettier": "3.8.1",
    "@tanstack/react-router": "1.158.1",
    "@tanstack/router-cli": "1.158.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "tailwind-merge": "3.3.1",
    "tailwindcss": "4.1.14"
  },
  "devDependencies": {
    "@eslint/js": "9.37.0",
    "@tanstack/router-devtools": "1.158.1",
    "@tanstack/router-vite-plugin": "1.158.1",
    "@types/node": "24.7.0",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react-swc": "3.8.0",
    "eslint": "9.22.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.4",
    "globals": "16.4.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.46.0",
    "vite": "6.2.1",
    "vite-plugin-node-polyfills": "0.24.0",
    "vite-tsconfig-paths": "5.1.4"
  }
}
