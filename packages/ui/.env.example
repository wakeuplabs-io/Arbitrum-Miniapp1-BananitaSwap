VITE_API_URL=http://localhost:3000
# RPC for app chain (Sepolia in dev/staging, mainnet in production)
VITE_RPC_URL_SEPOLIA=https://arb-sepolia.g.alchemy.com/v2/<your-key>
# Optional: mainnet RPC (for portfolio "View mainnet" and swap; uses public RPC if unset)
VITE_RPC_URL_MAINNET=https://arb-mainnet.g.alchemy.com/v2/<your-key>

# Rust/Stylus Diamond Router address per network
VITE_ROUTER_ADDRESS_SEPOLIA=0x<router-address-sepolia>
VITE_ROUTER_ADDRESS_MAINNET=0x<router-address-mainnet>

VITE_IS_TESTNET=false
