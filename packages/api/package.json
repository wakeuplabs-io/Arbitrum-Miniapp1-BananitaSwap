{
  "name": "@arbitrum-miniapp/api",
  "version": "1.0.0",
  "description": "API backend with Hono and Neon",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "drizzle-kit generate && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "verify-siwe": "tsx scripts/verify-siwe.ts",
    "fetch-usdc-tokens": "tsx scripts/fetch-usdc-paired-tokens.ts"
  },
  "keywords": [
    "api",
    "hono",
    "neon"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "@hono/zod-validator": "0.7.4",
    "@neondatabase/serverless": "1.0.2",
    "dotenv": "16.6.1",
    "drizzle-orm": "0.45.1",
    "esbuild": "0.25.11",
    "hono": "4.12.7",
    "jose": "5.9.6",
    "viem": "2.46.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.31.9",
    "pg": "8.16.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
