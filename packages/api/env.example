# Copy to .env.local in this directory and fill in values.
# See docs/environment-variables.md and packages/api/README.md

DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
PORT=3000
NODE_ENV=development
MAINNET_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/<your-key>
SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<your-key>
JWT_SECRET=<at-least-32-characters-long-random-string>

# Optional: IPFS pinning (metadata)
# PINATA_JWT=

# Optional: The Graph gateway key for token discovery (API logs a warning if missing)
# GRAPH_API_KEY=

# Optional: set to "true" or "false" if you need to override the default
# IS_TESTNET=

# Optional: filter token list; see src/services/token-allowlist-filter.ts
# TOKENS_APPLY_SWAP_ALLOWLIST=
